FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform ( 0 0 0 ); 

boundaryField
{
    inlet
    {
        type            waveVelocity;
        waveProperties  waveProperties;
        value           uniform ( 0 0 0 );
    }
    bottom
    {
        type            slip;
    }
    myCircle
    {
        type           movingWallVelocity;
        value          uniform ( 0 0 0 );
    }
    outlet
    {
        type            fixedValue;
        value           uniform ( 0 0 0 );
    }
    atmosphere
    {
        type            pressureInletOutletVelocity;
        value           uniform ( 0 0 0 );
    }
    frontBack
    {
        type            empty;
    }
}


