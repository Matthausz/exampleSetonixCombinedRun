FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      loggingProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

surfaceElevationIncident
{
    type waveGauge;

    pointDistribution lineDistribution;
    N 19;
    linestart (1.5 -0.1 0.005);
    lineend   (10.5 -0.1 0.005);
    add       ( 0 0.2 0);
    axis      y;
    stretch 1.;

    // REQURIED ONLY FOR NEW FUNCTIONOBJECT IMPLEMENTATION
    writeControl timeStep;
    writeInterval 25;
}
